# pythonStyle.mplstyle

# Use LaTeX for all text rendering
text.usetex: True

# LaTeX / Computer Modern style fonts
font.family: serif
font.serif: Computer Modern Roman, Times, Palatino, Serif

font.size: 18
axes.titlesize: 18
axes.labelsize: 18
xtick.labelsize: 14
ytick.labelsize: 14

lines.linewidth: 0.9
lines.marker: x
lines.markersize: 3
lines.markeredgewidth: 1.0
errorbar.capsize: 2

legend.fancybox: True
legend.framealpha: 0.9
legend.numpoints: 1
legend.scatterpoints: 1
legend.title_fontsize: 12
legend.fontsize: 12

axes.facecolor: 0.95
axes.edgecolor: white
axes.axisbelow: True

axes.grid: True
axes.grid.axis: both
grid.color: white
grid.linestyle: -
grid.linewidth: 1.5

xtick.major.size: 0
xtick.minor.size: 0
ytick.major.size: 0
ytick.minor.size: 0

axes.linewidth: 1
figure.autolayout: True
patch.linewidth: 1
patch.facecolor: 0,0.196078,0.372549
patch.edgecolor: white
patch.antialiased: True

# cholesky.errorbar.linewidth: 0.3
# cholesky.errorbar.capthick: 0.3
# cholesky.highlight.markersize: 7
# cholesky.highlight.markeredgewidth: 1.8
